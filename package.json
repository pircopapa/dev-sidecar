{
  "name": "dev-sidecar",
  "version": "1.8.0",
  "description": "开发者边车，github加速、npm加速、npm镜像、git加速、双击开启、自动配置代理",
  "main": "index.js",
  "scripts": {
    "dev": "node packages/gui/src/main/index.js",
    "start": "electron packages/gui",
    "build": "npm run build:core && npm run build:gui",
    "build:core": "cd packages/core && npm run build",
    "build:gui": "cd packages/gui && npm run build",
    "lint": "eslint packages --ext .js,.vue",
    "lint:fix": "eslint packages --ext .js,.vue --fix",
    "test": "jest",
    "postinstall": "node scripts/postinstall.js || exit 0",
    "clean": "rm -rf node_modules packages/core/node_modules packages/gui/node_modules"
  },
  "workspaces": [
    "packages/core",
    "packages/gui"
  ],
  "keywords": [
    "proxy",
    "github",
    "npm",
    "accelerate",
    "mirror",
    "developer",
    "sidecar"
  ],
  "author": "docmirror",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/docmirror/dev-sidecar.git"
  },
  "bugs": {
    "url": "https://github.com/docmirror/dev-sidecar/issues"
  },
  "homepage": "https://github.com/docmirror/dev-sidecar#readme",
  "devDependencies": {
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.17.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "_note": "personal fork for learning purposes - upstream: docmirror/dev-sidecar",
  "_fork_notes": "added 'clean' script for convenience when switching branches or troubleshooting install issues"
}
